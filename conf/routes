# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# Home
GET     /                           controllers.HomeController.index()

# Auth Pages
GET     /login                      controllers.AuthController.loginPage()
GET     /register                   controllers.AuthController.registerPage()

# Auth Form Submit
POST    /login                      controllers.AuthController.login()
POST    /register                   controllers.AuthController.register()
POST    /logout                     controllers.AuthController.logout()

# Todo SSR
GET     /todos                      controllers.TodoController.index()
POST    /todos/create               controllers.TodoController.create()
GET     /todos/:id/edit             controllers.TodoController.edit(id: String)
POST    /todos/:id/update           controllers.TodoController.update(id: String)
POST    /todos/:id/delete           controllers.TodoController.delete(id: String)
POST    /todos/:id/toggle           controllers.TodoController.toggle(id: String)

# Admin
GET     /admin                      controllers.AdminController.dashboard()
GET     /admin/users                controllers.AdminController.users()

# Static assets
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)