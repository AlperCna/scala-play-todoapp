# Kafka placeholders (Phase 1 reference)
kafka {
  enabled = false
  bootstrapServers = "localhost:9092"
  clientId = "todo-play-app"
  topic.todoEvents = "todo.events.v1"
  producer.acks = "all"
  producer.enableIdempotence = true
  producer.requestTimeoutMs = 30000
  producer.deliveryTimeoutMs = 120000
  producer.maxInFlightRequestsPerConnection = 5
  outbox.pollIntervalSeconds = 15
  outbox.batchSize = 20
  outbox.maxAttempts = 5
  outbox.initialRetryDelaySeconds = 30
}
